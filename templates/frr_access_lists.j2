{% for a in lookup('ansible.builtin.vars', 'frr_router_access_lists') %}
{% if a['name'] is defined and a['name'] not in ['', [], '[]', None] %}
{% if a['remark'] is defined and a['remark'] not in ['', [], '[]', None] %}
{{ 'access-list ' + a['name'] + ' remark ' + a['remark'] }}
{% endif %}
{% if a['rules'] is defined and a['rules'] not in ['', [], '[]', None] %}
{% for acl in a['rules'] %}
{{ 'access-list ' ~ a['name'] ~ ' seq ' ~ (loop['index'] * 5) ~ ' ' ~ acl }}
{% endfor %}
{% endif %}
{% endif %}
{% if loop['last'] %}
{{ '!' }}
{% endif %}
{% endfor %}
