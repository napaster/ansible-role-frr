{% for i in lookup('ansible.builtin.vars', 'frr_interfaces') %}
{% if i['name'] is defined and i['name'] not in ['', [], '[]', None] %}
{{ 'interface ' + i['name'] }}
{% if i['description'] is defined and i['description']
  not in ['', [], '[]', None] %}
{{ ' description ' + i['description'] }}
{% endif %}
{% if i['link_detect'] is defined and i['link_detect'] == 'true' %}
{{ ' link-detect' }}
{% endif %}
{% if i['ip'] is defined and i['ip'] not in ['', [], '[]', None] %}
{% for ii in i['ip'] %}
{% if (ii['address'] is defined and ii['address'] not in ['', [], '[]', None])
  and ((ii['address'] | ansible.utils.ipaddr('host')) is ansible.utils.ip()) %}
{{ ' ip address ' + ii['address'] -}}
{% if ii['label'] is defined and ii['label'] not in ['', [], '[]', None] %}
{{ ' label ' + ii['label'] -}}
{% endif %}
{{ '' }}
{% endif %}
{% if ii['ospf'] is defined and ii['ospf'] not in ['', [], '[]', None] %}
{% for iio in ii['ospf'] %}
{% include 'frr_interface/frr_interface_ospf.j2' %}
{% endfor %}
{% endif %}
{% endfor %}
{% endif %}
{% endif %}
{% if i['pbr_policy'] is defined and i['pbr_policy']
  not in ['', [], '[]', None] %}
{{ ' pbr-policy ' ~ i['pbr_policy'] }}
{% endif %}
{% if i['multicast'] is defined and i['multicast'] == 'true' %}
{{ ' multicast' }}
{% endif %}
{% if i['vrrp'] is defined and i['vrrp'] not in ['', [], '[]', None] %}
{% for iv in i['vrrp'] %}
{% include 'frr_interface/frr_interface_vrrp.j2' %}
{% endfor %}
{% endif %}
{{ 'exit' }}
{{ '!' }}
{% endfor %}
